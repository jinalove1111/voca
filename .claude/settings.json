{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\voca\\scripts\\hooks\\checkDestructiveSql.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\voca\\scripts\\hooks\\suggestVerifyDomain.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
